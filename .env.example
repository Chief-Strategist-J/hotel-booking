# Database — matches docker-compose.yml credentials
DATABASE_URL="postgresql://hotel:hotel123@localhost:5432/hotel_db"

# Auth
NEXTAUTH_SECRET="change-this-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Paystack
PAYSTACK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_..."

# Storage (Cloudflare R2 or AWS S3)
STORAGE_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="hotel-images"
STORAGE_PUBLIC_URL="https://pub.your-domain.com"

# Email
# Local dev: Mailhog (included in docker-compose) — view at http://localhost:8025
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
# Production: replace with real SMTP (Gmail, Resend, etc.)
EMAIL_FROM="Hotel <noreply@hotel.com>"
ADMIN_EMAIL="admin@hotel.com"
